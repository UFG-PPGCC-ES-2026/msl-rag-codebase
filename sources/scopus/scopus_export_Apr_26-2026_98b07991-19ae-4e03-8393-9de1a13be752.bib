}

@CONFERENCE{Sun20254462,
	author = {Sun, Tianze and Wang, Zekun and Wang, Wei and Chen, Ran and Pei, Ji},
	title = {Teacher-Guided Code Generation With API Update},
	year = {2025},
	journal = {Conference Proceedings - IEEE International Conference on Systems, Man and Cybernetics},
	pages = {4462 - 4468},
	doi = {10.1109/SMC58881.2025.11342663},
	url = {https://www.scopus.com/pages/publications/105033153463?origin=resultslist},
	abstract = {Large language models have shown considerable potential in areas such as program writing and API invocation, significantly enhancing automation and efficiency. However, frequent updates to APIs pose significant challenges to these models, particularly in terms of the high costs of retraining and the complexity of maintenance associated with updating the model's knowledge. Current strategies for handling these issues generally fall into two categories: enhanced reasoning and parameter tuning. Among these, Retrieval Augmented Generation (RAG), as a primary method for enhancing reasoning, assists the code models in the reasoning process during code generation by modifying prompt information. However, since it does not alter the model's parameters, external knowledge may conflict with the knowledge stored in the model after training; On the other hand, the method of parameter tuning incorporates API updates into the training data, modifying the code model's parameters and enabling re-reasoning. However it struggles due to the scarcity of high-quality samples for effective model training. In response to these challenges, we propose an innovative learning method that utilizes the logical reasoning capabilities of generic large models and adopts a teacher-student framework. Within our framework, the teacher model analyzes the historical learning records of the code model to autonomously generate high-quality programming problems and their solutions, guiding the model through preference-based training. This approach not only leverages the strengths of large models in problem generation but also strictly controls the quality of learning materials, effectively avoiding the knowledge conflicts that can arise from RAG-based methods. Our Method offers a more effective and practical solution for code models in rapidly evolving API environments, significantly improving their stability and accuracy in practical applications. Experiments conducted across multiple common code repositories have demonstrated the significant advantages of our method, confirming its proactive and practical capabilities in addressing the challenges of API updates. © 2025 IEEE.},
	issn = {1062922X},
	isbn = {979-833153358-8},
	coden = {PICYE},
	language = {English},
	abbrev_source_title = {Conf. Proc. IEEE Int. Conf. Syst. Man Cybern.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Pan2025,
	author = {Pan, Jingyu and Jacobson, Isaac and Zhao, Zheng and Chen, Tung-Chieh and Zhou, Guanglei and Chang, Chen-Chia and Rashingkar, Vineet and Chen, Yiran},
	title = {CROP: Circuit Retrieval and Optimization with Parameter Guidance using LLMs},
	year = {2025},
	journal = {IEEE/ACM International Conference on Computer-Aided Design, Digest of Technical Papers, ICCAD},
	pages = {},
	doi = {10.1109/ICCAD66269.2025.11240643},
	url = {https://www.scopus.com/pages/publications/105029379578?origin=resultslist},
	abstract = {Modern very large-scale integration (VLSI) design requires the implementation of integrated circuits using electronic design automation (EDA) tools. Due to the complexity of EDA algorithms, the vast parameter space poses a huge challenge to chip design optimization, as the combination of even moderate numbers of parameters creates an enormous solution space to explore. Manual parameter selection remains industrial practice despite being excessively laborious and limited by expert experience. To address this issue, we present CROP, the first large language model (LLM)-powered automatic VLSI design flow tuning framework. Our approach includes: (1) a scalable methodology for transforming RTL source code into dense vector representations, (2) an embedding-based retrieval system for matching designs with semantically similar circuits, and (3) a retrieval-augmented generation (RAG)-enhanced LLM-guided parameter search system that constrains the search process with prior knowledge from similar designs. Experiment results demonstrate CROP's ability to achieve superior quality-of-results (QoR) with fewer iterations than existing approaches on industrial designs, including a 9.9% reduction in power consumption.  © 2025 IEEE.},
	author_keywords = {design automation; large language models; parameter tuning},
