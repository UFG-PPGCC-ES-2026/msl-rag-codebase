@ARTICLE{Borrelli2026,
	author = {Borrelli, Anna and De Angelis, Valentina and Izzo, Stefano and Giampaolo, Fabio and Piccialli, Francesco},
	title = {MAKES-QA: A multi-agent framework for knowledge graph construction and enrichment over scientific literature for question answering},
	year = {2026},
	journal = {Expert Systems with Applications},
