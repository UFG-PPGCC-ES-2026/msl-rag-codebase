@CONFERENCE{Chaudhury202511696,
	author = {Chaudhury, Subhajit and Das, Payel and Swaminathan, Sarathkrishna and Kollias, Georgios and Nelson, Elliot and Pahwa, Khushbu and Pedapati, Tejaswini and Melnyk, Igor and Riemer, Matthew},
	title = {EpMAN: Episodic Memory AttentioN for Generalizing to Longer Contexts},
	year = {2025},
	journal = {Proceedings of the Annual Meeting of the Association for Computational Linguistics},
	volume = {1},
	pages = {11696 - 11708},
	doi = {10.18653/v1/2025.acl-long.574},
	url = {https://www.scopus.com/pages/publications/105021011546?origin=resultslist},
	abstract = {Recent advances in Large Language Models (LLMs) have yielded impressive successes on many language tasks. However, efficient processing of long contexts using LLMs remains a significant challenge. We introduce EpMAN - a method for processing long contexts in an episodic memory module while holistically attending to semantically relevant context chunks. The output of episodic attention is then used to reweigh the decoder's self-attention to the stored KV cache of the context during training and generation. When an LLM decoder is trained using EpMAN, its performance on multiple challenging single-hop long-context recall and question-answering benchmarks is found to be stronger and more robust across the range from 16k to 256k tokens than baseline decoders trained with self-attention, and popular retrieval-augmented generation frameworks. Our source code will be made available at https://github.com/IBM/epman. © 2025 Association for Computational Linguistics.},
