	abbrev_source_title = {IEEE ACM Int. Conf. Comput. Des. Dig. Tech. Pap. ICCAD},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

@CONFERENCE{Han20251300,
	author = {Han, Derrick Lim Jo and Ng, Pai Chet and Low, Malcolm Yoke Hean},
