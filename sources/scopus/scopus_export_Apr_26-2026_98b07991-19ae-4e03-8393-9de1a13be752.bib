@CONFERENCE{Naulty2025613,
	author = {Naulty, John E. and Chen, Eason and Wang, Joy and Digkas, George and Chalkias, Kostas},
	title = {Bugdar: AI-Augmented Secure Code Review for GitHub Pull Requests},
