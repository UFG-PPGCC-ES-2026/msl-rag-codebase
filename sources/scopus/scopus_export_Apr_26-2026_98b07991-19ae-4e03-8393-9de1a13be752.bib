}

@CONFERENCE{Carthen2025238,
	author = {Carthen, Chase and Lac, Lukas and White, Rich and Braun, Thomas and Ochoa, Josue and Tavakkoli, Alireza and Harris, Frederick C.},
	title = {N-CATS: A Neural Network Classification Automatic Taxonomy System},
	year = {2025},
	journal = {Proceedings - 29th IEEE/ACIS International Conference on Software Engineering, Artificial Intelligence, Networking and Parallel/Distributed Computing, SNPD 2025-Summer},
	pages = {238 - 243},
	doi = {10.1109/SNPD65828.2025.11254174},
	url = {https://www.scopus.com/pages/publications/105031173596?origin=resultslist},
	abstract = {The rapid evolution of Artificial Neural Networks (ANN) has made it difficult to organize and compare model architectures under a unified framework. Automatic taxonomy construction (ATC) is a promising approach for algorithmically organizing knowledge domains, but existing frameworks struggle with the structural complexities of ANNs. To address this, we introduce Neural Network Classification Automatic Taxonomy System (N-CATS), a structured, ontology-driven framework for ATC that enables comparison across diverse ANN topologies. N-CATS extracts contextual information from semi-structured sources, including academic publications, source code, and serialized formats such as ONNX to populate an ontology schema-based on ANNETT-O. The system leverages Large Language Models (LLM) with Retrieval-Augmented Generation (RAG) to support the ontology population and organize extracted information in a graph database, enabling on-demand categorization and comparison of ANNs. To demonstrate feasibility, we developed a web application that provides ontology visualization, proof-of-concept taxonomy generation, and a chatbot using GraphRAG and Model Context Protocol (MCP) servers for intelligent querying. We compare N-CATS with existing neural network ontologies such as FAIRnets, Artificial Intelligence Ontology (AIO), and ANNETT-O. Finally, we outline advantages and limitations, demonstrating a proof-of-concept knowledge system that facilitates more efficient discovery and comparison of deep learning models as a tool for researchers.  © 2025 IEEE.},
	author_keywords = {Automatic Taxonomy Construction; Model Context Protocol; Neural Network; Ontology; Retrieval Augmented Generation},
	isbn = {979-833151258-3},
	language = {English},
	abbrev_source_title = {Proc. - IEEE/ACIS Int. Conf. Softw. Eng., Artif. Intell., Netw. Parallel/Distrib. Comput., SNPD-Summer},
