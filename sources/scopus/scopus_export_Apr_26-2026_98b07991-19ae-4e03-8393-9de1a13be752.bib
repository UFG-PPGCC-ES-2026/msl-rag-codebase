@ARTICLE{Zhang2026,
	author = {Zhang, Zhuorui and Feng, Shanshan and Yang, Tiance and Huang, Ruobing and Wang, Hao and Wang, Fu and Li, Fan},
	title = {AviationCopilot: Building a reliable LLM-based Aviation Copilot inspired by human pilot training},
	year = {2026},
	journal = {Advanced Engineering Informatics},
	volume = {69},
	pages = {},
	doi = {10.1016/j.aei.2025.103806},
	url = {https://www.scopus.com/pages/publications/105015142983?origin=resultslist},
	abstract = {Modern pilots routinely face high cognitive loads during complex flight operations. Although large language models (LLMs) demonstrate exceptional natural language understanding and exhibit tremendous potential as copilots, there is a notable gap in LLMs specifically designed to handle the knowledge-intensive tasks required of pilots. Inspired by pilots’ learning and manual retrieval patterns, we introduce AviationCopilot—a novel framework that efficiently injects both aviation knowledge content and knowledge structure into LLMs. Specifically, we employ differentiated data fusion and generalization strategies for two training stages including continual pre-training and instruction tuning. This approach equips the model with enhanced domain-specific knowledge retention and instruction-following capabilities, akin to human pilots. During inference, AviationCopilot activates its knowledge structure memory to adaptively retrieve comprehensive context, improving factual accuracy. To evaluate effectiveness, we construct a comprehensive benchmark named OpenAviation featuring both LLM-synthesized and expert-designed questions. Experimental results show that models with fewer than two billion parameters, trained with the AviationCopilot framework, consistently outperform strong LLM baselines, including those utilizing Retrieval-Augmented Generation (RAG). Additionally, AviationCopilot enhances structured aviation understanding and enables LLMs to serve as retrievers for improving other models, supporting more reliable AI copilots. The dataset and source code are available at https://github.com/zhuorui-zhang/AviationCopilot. © 2025},
	author_keywords = {Aviation AI copilot; Aviation knowledge injection; Knowledge-structure-aware training; Large language models (LLMs); OpenAviation benchmark},
	issn = {14740346},
	language = {English},
	abbrev_source_title = {Adv. Eng. Inf.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3}
}

@ARTICLE{Xiaotian2025,
	author = {Xiaotian, Tu and Xiaosong, Zhang and Ruidong, Chen},
	title = {Collaborative Agent Framework for Web Vulnerability Discovery in Source Code},
	year = {2025},
	journal = {International Computer Conference on Wavelet Active Media Technology and Information Processing, ICCWAMTIP},
	pages = {},
	doi = {10.1109/ICCWAMTIP68645.2025.11352622},
	url = {https://www.scopus.com/pages/publications/105033227882?origin=resultslist},
	abstract = {Web applications are gradually becoming the main entry points for attackers to exploit vulnerabilities and launch attacks. Existing dynamic testing tools struggle to reach deep program logic because they cannot handle path constraints, while static testing tools are limited by language-specific rules and expert experience, making it difficult to effectively cover multi-language code in Web applications. To address these limitations, this paper proposes a new Web vulnerability discovery method based on Large Language Model (LLM), called VoidSight. Void-Sight adopts a novel three-stage integrated architecture. This architecture integrates Retrieval-Augmented Generation, code embeddings, and the CAMEL multi-agent dialogue framework, thereby transforming vulnerability detection from similarity matching based on static code representations into an interactive reasoning process with active information acquisition. The process first extracts 5,613 CVE records from GitHub security advisories, cleans them, and filters out key vulnerability code lines in PHP, Java, JavaScript, TypeScript, Python, and Go. Then, for each line of vulnerability code, it generates semantically equivalent code snippets in other languages and uses embedding models to match similar vulnerability lines. Finally, two agents, the 'Web Frontend Vulnerability Verifier' and 'Code Vulnerability Researcher' collaborate to track along data flows and evaluate vulnerability exploitability. To date, VoidSight has identified 12 vulnerabilities in 8 projects on GitHub. After reporting them to developers via email and issue, we obtained 12 CVE IDs. Under the joint scanning of Semgrep, SonarQube, ZAP, and Nikto, 8 vulnerabilities were not detected  © 2025 IEEE.},
	author_keywords = {Code similarity search; Large language models; Multi-agent systems; Retrieval-augmented generation; Web application vulnerabilities},
	issn = {25768972},
	isbn = {979-833159376-6},
	language = {English},
